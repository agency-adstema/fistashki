# Application
NODE_ENV=development
PORT=4000
# Comma-separated. Shop (kucabasta.rs) + admin CRM must be allowed when API is on another host (e.g. api.adstema.com).
CORS_ORIGIN=http://localhost:3000,https://kucabasta.rs,https://www.kucabasta.rs,https://admin.adstema.com

# Public URL for /uploads (shop must load images from this host; no trailing slash)
# Example production: https://api.yourdomain.com
PUBLIC_ASSET_BASE_URL=

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/ecommerce_db?schema=public"

# JWT
JWT_SECRET=super_secret_jwt_key_change_this_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# Redis (za BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Yeastar PBX
YEASTAR_HOST=192.168.1.100
YEASTAR_PORT=8088
YEASTAR_USERNAME=admin
YEASTAR_PASSWORD=admin

# OpenAI Realtime API
OPENAI_API_KEY=sk-proj-...
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
OPENAI_VOICE=nova
OPENAI_LANGUAGE=sr
OPENAI_SYSTEM_PROMPT=Ti si ljubazna i profesionalna zastupnica prodaje. Zoveš kupce da potvrdiš njihove narudžbine. Budi topla, razumevajuća i uspešna u prodaji.

# Blog SEO text + hero images (uses OPENAI_API_KEY)
# OPENAI_SEO_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=dall-e-3

# Call Center
CALL_FROM_NUMBER=+381000000
COMPANY_NAME=My Store
